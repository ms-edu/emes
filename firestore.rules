// firestore.rules
// Deploy: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Licenses ─────────────────────────────────────────────────────────────
    match /licenses/{docId} {
      allow read: if false;   // Admin SDK bypass — client tidak boleh baca langsung
      allow write: if false;
    }

    // ─── Resellers ────────────────────────────────────────────────────────────
    match /resellers/{docId} {
      allow read: if true;   // publik (dipakai [code].js & landing page)
      allow write: if false; // hanya Admin SDK
    }

    // ─── Pendaftar ────────────────────────────────────────────────────────────
    match /pendaftar/{docId} {
      allow create: if request.resource.data.keys().hasAll(['nama_sekolah', 'wa', 'created_at'])
                    && request.resource.data.nama_sekolah is string
                    && request.resource.data.nama_sekolah.size() > 2;
      allow read, update, delete: if false;
    }

    // ─── Invoices ─────────────────────────────────────────────────────────────
    match /invoices/{docId} {
      allow read, write: if false; // hanya Admin SDK
    }

    // ─── Settings ─────────────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read: if true;   // publik (untuk komisi_persen di landing)
      allow write: if false;
    }

    // ─── Downloads (counter publik) ───────────────────────────────────────────
    match /stats/{docId} {
      allow read: if true;   // publik — untuk counter download di landing page
      allow write: if false; // hanya Admin SDK
    }

    // ─── Downloads (Firestore dari download gate) ─────────────────────────────
    match /downloads/{docId} {
      allow create: if true; // pengguna baru bisa mendaftar via landing page
      allow read, update, delete: if false;
    }

    // Blokir semua koleksi lain
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
